# pulseaudio_binaural.pa
# Example ~/.config/pulse/default.pa snippet or system snippet
# to enable binaural (crossfeed) using bs2b LADSPA plugin.
#
# .include the stock one, then add:

.include /etc/pulse/default.pa
load-module module-ladspa-sink sink_name=binaural sink_master=alsa_output.pci-0000_00_1b.0.analog-stereo plugin=bs2b label=bs2b control=700,4.5
set-default-sink binaural
